{
  "_metadata": {
    "framework": "atlas_coverage",
    "schema_version": "1.0",
    "description": "Maps every atlas organ (259 entities) to its state-model organ. Atlas has fine anatomical granularity (r_kidney + l_kidney separate, individual vessels, individual nerves). State model has functional granularity (16 organ types). This mapping bridges them so atlas-derived propagation can find the right state for any atlas entity.",
    "source": "Manual mapping based on functional anatomy",
    "review_status": "unreviewed"
  },
  "_kind_categories": {
    "_comment": "Each atlas organ belongs to one of these kinds. Vessels/nerves are 'pathways', not organs with state models.",
    "organ": "functional tissue with state variables (state_model maps here)",
    "vessel": "blood vessel — has perfusion role but no own state model",
    "nerve": "peripheral nerve — has signaling role but no own state model",
    "duct": "lumen / conduit — has flow role but no own state model",
    "region": "anatomical region label (not a tissue)",
    "barrier": "membrane / capsule (e.g. meninges, pleura)",
    "structural": "supporting structure (e.g. ligament, fascia)",
    "lymph_node": "specific lymph station — drains into hematologic"
  },
  "atlas_to_state_organ": {
