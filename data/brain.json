        }
      ]
    },
    "Alzheimer's Dementia": {
      "_review_status": "unreviewed",
      "description": "Progressive cortical dementia from amyloid + tau pathology — hippocampus early.",
      "perturbations": [
        {
          "variable": "amyloid_burden",
          "delta": 0.65,
          "cause": "Aβ42 plaque deposition"
        },
        {
          "variable": "cholinergic_function",
          "delta": -0.5,
          "cause": "basal forebrain cholinergic loss"
        },
        {
          "variable": "synaptic_function",
          "delta": -0.45,
          "cause": "neuritic plaque + tau tangle disruption"
        }
      ]
    },
    "Parkinson Disease": {
