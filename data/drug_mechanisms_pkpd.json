{
  "_metadata": {
    "schema_version": "2.0-pkpd",
    "description": "Drug mechanism map for NEXUS treatment recommendation (#10) and drug-response inference (#5). Each drug declares which organ states it modulates (state_effects) \u2014 treatment recs auto-match drugs to diseases whose perturbations need correcting. No hardcoded disease->drug lookups.",
    "review_status": "unreviewed",
    "field_reference": {
      "relieves": "symptoms this drug relieves (feeds drug-response inference #5)",
      "supports_diseases": "if drug relieved a symptom, which diseases get boosted (lowercase)",
      "drug_class": "groups drugs for class-diverse treatment ranking",
      "state_effects": "[{organ, variable, direction}] \u2014 the mechanism core. direction low=pushes state down, high=pushes up, organ '*'=any organ",
      "rationale": "human-readable mechanism note",
      "max_delta": "signed magnitude of this effect at full PD strength; sign MUST match direction (low<0, high>0). Engine uses this; recommender uses direction.",
      "pk": "{routes:{route:{bioavailability,ka_per_hr}}, vd_L_per_kg, cl_L_per_hr_per_kg, fraction_renal_clearance, reference_dose_mg, reference_route}. ke and t1/2 are DERIVED.",
      "pd": "{benefit:{emax,ec50_norm,hill}, toxicity:{emax,ec50_norm,hill}} on normalized concentration scale (1.0 \u2248 reference-dose peak).",
      "toxic_effects": "state effects driven by the toxicity Emax curve",
      "parameterized": "true=full dose-time sim; false=legacy direction-only",
      "SAFETY": "All pk/pd values are ESTIMATED, not clinical. Mechanistic simulation only \u2014 never a dosing recommendation."
    }
  },
