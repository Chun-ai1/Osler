{
  "_metadata": {
    "organ": "gi",
    "schema_version": "1.0",
    "description": "Gastrointestinal state model. Used by gastroenteritis, GERD, IBD, cholecystitis, appendicitis (when added).",
    "source": "Boron & Boulpaep GI Physiology; Harrison's IM Gastroenterology section",
    "review_status": "unreviewed"
  },
  "state_variables": {
    "mucosal_inflammation": {
      "range": [
        0,
        1
      ],
      "description": "GI mucosal/submucosal inflammation"
    },
    "motility": {
      "range": [
        0,
        1
      ],
      "description": "peristalsis intensity — normal=0.5, hypermotility=high, ileus=low",
      "default": 0.5
    },
    "secretion": {
      "range": [
        0,
        1
      ],
      "description": "luminal fluid secretion (cAMP-driven)",
      "default": 0.5
    },
    "acid_exposure": {
      "range": [
        0,
        1
      ],
      "description": "esophageal/gastric mucosa exposure to acid"
    },
    "lower_esophageal_sphincter_tone": {
      "range": [
        0,
        1
      ],
      "description": "LES competence — HIGHER = better closure",
      "inverse": true,
      "default": 0.5
    },
    "visceral_nociception": {
      "range": [
        0,
        1
      ],
      "description": "afferent pain signaling from GI wall"
    },
    "vomiting_center_activation": {
      "range": [
        0,
        1
      ],
      "description": "medullary CTZ + vomiting center drive"
    },
    "luminal_pathogen": {
      "range": [
        0,
        1
      ],
      "description": "enteric pathogen load"
    },
    "absorption_capacity": {
      "range": [
        0,
        1
      ],
      "description": "fluid/nutrient absorption — HIGHER = better",
      "inverse": true
    },
    "luminal_obstruction": {
      "range": [
        0,
        1
      ],
      "description": "mechanical bowel obstruction"
    },
    "mucosal_ulceration": {
      "range": [
        0,
        1
      ],
      "description": "ulcer / erosion of mucosa"
    },
    "transit_time": {
      "range": [
        0,
        1
      ],
      "description": "rate of bowel transit (0.5 normal, low = constipation, high = diarrhea)",
      "default": 0.5
    },
    "malabsorption": {
      "range": [
        0,
        1
      ],
      "description": "impaired absorption of nutrients"
    }
  },
  "derivation_rules": [
    {
      "symptom": "diarrhea",
      "condition": {
        "any": [
          {
            "all": [
              {
                "state": "secretion",
                "op": ">",
                "threshold": 0.5
              },
              {
                "state": "motility",
                "op": ">",
                "threshold": 0.5
              }
            ]
          },
          {
            "state": "absorption_capacity",
            "op": "<",
            "threshold": 0.4
          }
        ]
      },
      "rationale": "increased intestinal secretion + hypermotility OR impaired absorption → loose stools",
      "confidence": 1.0
    },
    {
      "symptom": "nausea",
      "condition": {
        "state": "vomiting_center_activation",
        "op": ">",
        "threshold": 0.4
      },
      "rationale": "medullary CTZ activation from pathogen toxins, distension, or visceral afferents → nausea sensation",
      "confidence": 1.0
    },
    {
      "symptom": "vomiting",
      "condition": {
        "state": "vomiting_center_activation",
        "op": ">",
        "threshold": 0.6
      },
      "rationale": "strong vomiting center drive triggers reverse peristalsis + diaphragm contraction",
      "confidence": 1.0
    },
    {
      "symptom": "abdominal cramps",
      "condition": {
        "all": [
          {
            "state": "motility",
            "op": ">",
            "threshold": 0.5
          },
          {
            "state": "visceral_nociception",
            "op": ">",
            "threshold": 0.4
          }
        ]
      },
      "rationale": "hypermotility + visceral afferent activation → crampy intermittent pain",
      "confidence": 1.0
    },
    {
      "symptom": "abdominal pain",
      "condition": {
        "state": "visceral_nociception",
        "op": ">",
        "threshold": 0.5
      },
      "rationale": "visceral afferent nociceptors activated by inflammation or distension",
      "confidence": 0.9
    },
    {
      "symptom": "heartburn",
      "condition": {
        "state": "acid_exposure",
        "op": ">",
        "threshold": 0.5
      },
      "rationale": "acid contact with esophageal mucosa activates afferent fibers — burning retrosternal sensation",
      "confidence": 1.0
    },
    {
      "symptom": "acid reflux",
      "condition": {
        "all": [
          {
            "state": "lower_esophageal_sphincter_tone",
            "op": "<",
            "threshold": 0.5
          },
          {
            "state": "acid_exposure",
            "op": ">",
            "threshold": 0.4
          }
        ]
      },
      "rationale": "LES incompetence allows gastric content to reflux into esophagus",
      "confidence": 1.0
    },
    {
      "symptom": "regurgitation",
      "condition": {
        "state": "lower_esophageal_sphincter_tone",
        "op": "<",
        "threshold": 0.3
      },
      "rationale": "severe LES dysfunction allows passive reflux of food/fluid to mouth",
      "confidence": 0.9
    },
    {
      "symptom": "fever",
      "condition": {
        "state": "mucosal_inflammation",
        "op": ">",
        "threshold": 0.6
      },
      "rationale": "GI inflammation releases pyrogens → hypothalamic setpoint elevation",
      "confidence": 0.8
    },
    {
      "symptom": "loss of appetite",
      "condition": {
        "state": "mucosal_inflammation",
        "op": ">",
        "threshold": 0.5
      },
      "rationale": "inflammatory cytokines suppress hypothalamic appetite centers",
      "confidence": 0.8
    },
    {
      "symptom": "constipation",
      "condition": {
        "state": "transit_time",
        "op": "<",
        "threshold": 0.35
      },
      "rationale": "slowed bowel transit",
      "confidence": 1.0
    },
    {
      "symptom": "diarrhea",
      "condition": {
        "state": "transit_time",
        "op": ">",
        "threshold": 0.7
      },
      "rationale": "rapid bowel transit",
      "confidence": 1.0
    },
    {
      "symptom": "abdominal distension",
      "condition": {
        "state": "luminal_obstruction",
        "op": ">",
        "threshold": 0.5
      },
      "rationale": "gas + fluid accumulation proximal to obstruction",
      "confidence": 1.0
    },
    {
      "symptom": "obstipation",
      "condition": {
        "state": "luminal_obstruction",
        "op": ">",
        "threshold": 0.6
      },
      "rationale": "complete obstruction → no stool or gas passage",
      "confidence": 1.0
    },
    {
      "symptom": "melena",
      "condition": {
        "state": "mucosal_ulceration",
        "op": ">",
        "threshold": 0.5
      },
      "rationale": "ulcer bleeding from upper GI source → digested blood",
      "confidence": 0.9
    },
    {
      "symptom": "weight loss",
      "condition": {
        "state": "malabsorption",
        "op": ">",
        "threshold": 0.5
      },
      "rationale": "nutrient malabsorption",
      "confidence": 0.8
    },
    {
      "symptom": "chest pain",
      "condition": {
        "state": "acid_exposure",
        "op": ">",
        "threshold": 0.5
      },
      "rationale": "severe acid reflux can mimic cardiac chest pain (non-cardiac chest pain)",
      "confidence": 0.6
    },
    {
      "symptom": "hematemesis",
      "condition": {
        "state": "mucosal_ulceration",
        "op": ">",
        "threshold": 0.6
      },
      "rationale": "esophageal ulcer with active bleeding",
      "confidence": 0.7
    },
    {
      "symptom": "dysphagia",
      "condition": {
        "state": "mucosal_ulceration",
        "op": ">",
        "threshold": 0.5
      },
      "rationale": "severe esophagitis → odynophagia + dysphagia",
      "confidence": 0.7
    }
  ],
  "diseases": {
    "Acute Gastroenteritis": {
      "review_status": "unreviewed",
      "description": "Viral (norovirus, rotavirus) or bacterial enteritis. Pathogen triggers secretion + hypermotility + vomiting → diarrhea/nausea/cramps.",
      "perturbations": [
        {
          "variable": "luminal_pathogen",
          "delta": 0.8,
          "cause": "enteric pathogen colonization"
        },
        {
          "variable": "mucosal_inflammation",
          "delta": 0.65,
          "cause": "epithelial damage from pathogen + cytokine response"
        },
        {
          "variable": "secretion",
          "delta": 0.7,
          "cause": "toxin-stimulated chloride/water secretion"
        },
        {
          "variable": "motility",
          "delta": 0.65,
          "cause": "irritated bowel hypermotility (host defense to expel pathogen)"
        },
        {
          "variable": "visceral_nociception",
          "delta": 0.55,
          "cause": "inflammation activates mesenteric afferents"
        },
        {
          "variable": "vomiting_center_activation",
          "delta": 0.6,
          "cause": "toxins reach CTZ via bloodstream + vagal afferents"
        },
        {
          "variable": "absorption_capacity",
          "delta": -0.5,
          "cause": "damaged enterocytes lose absorptive function"
        }
      ]
    },
    "Gastroesophageal Reflux Disease": {
      "review_status": "unreviewed",
      "description": "Gastroesophageal reflux disease — LES incompetence allows gastric acid to reflux into esophagus, causing mucosal irritation.",
      "perturbations": [
        {
          "variable": "acid_exposure",
          "delta": 0.55,
          "cause": "chronic LES incompetence allows acid reflux"
        },
        {
          "variable": "lower_esophageal_sphincter_tone",
          "delta": -0.4,
          "cause": "LES hypotonia (obesity, hiatal hernia, food/drug)"
        }
      ]
    },
    "Acute Appendicitis": {
      "_review_status": "unreviewed",
      "description": "Acute appendiceal inflammation — periumbilical → RLQ migration.",
      "perturbations": [
        {
          "variable": "mucosal_inflammation",
          "delta": 0.65,
          "cause": "luminal obstruction → bacterial overgrowth in appendix"
        },
        {
          "variable": "visceral_nociception",
          "delta": 0.6,
          "cause": "appendix wall distension"
        }
      ]
    },
    "Acute Diverticulitis": {
      "_review_status": "unreviewed",
      "description": "Inflammation of colonic diverticula (typically sigmoid) — LLQ pain.",
      "perturbations": [
        {
          "variable": "mucosal_inflammation",
          "delta": 0.6,
          "cause": "fecalith → diverticular inflammation"
        },
        {
          "variable": "visceral_nociception",
          "delta": 0.5,
          "cause": "colonic wall inflammation"
        }
      ]
    },
    "Erosive Esophagitis": {
      "_review_status": "unreviewed",
      "description": "Severe acid reflux → esophageal mucosal erosion.",
      "perturbations": [
        {
          "variable": "acid_exposure",
          "delta": 0.55,
          "cause": "severe prolonged reflux"
        },
        {
          "variable": "mucosal_ulceration",
          "delta": 0.65,
          "cause": "acid-induced erosion (LA grade B-D)"
        },
        {
          "variable": "lower_esophageal_sphincter_tone",
          "delta": -0.45,
          "cause": "LES dysfunction underlying"
        }
      ]
    },
    "Peptic Ulcer Disease": {
      "_review_status": "unreviewed",
      "description": "Gastric or duodenal ulcer (H. pylori or NSAID-related).",
      "perturbations": [
        {
          "variable": "mucosal_ulceration",
          "delta": 0.65,
          "cause": "H. pylori or NSAID-induced mucosal injury"
        },
        {
          "variable": "acid_exposure",
          "delta": 0.4,
          "cause": "acid contributes to ulcer formation"
        }
      ]
    },
    "Small Bowel Obstruction": {
      "_review_status": "unreviewed",
      "description": "Mechanical obstruction of small intestine (adhesions, hernia, tumor).",
      "perturbations": [
        {
          "variable": "luminal_obstruction",
          "delta": 0.75,
          "cause": "adhesion / hernia / tumor"
        },
        {
          "variable": "motility",
          "delta": -0.55,
          "cause": "obstruction → ileus distal, increased proximal"
        }
      ]
    },
    "Inflammatory Bowel Disease": {
      "_review_status": "unreviewed",
      "description": "Crohn or ulcerative colitis — chronic immune-mediated bowel inflammation.",
      "perturbations": [
        {
          "variable": "mucosal_inflammation",
          "delta": 0.65,
          "cause": "T-cell mediated chronic inflammation"
        },
        {
          "variable": "mucosal_ulceration",
          "delta": 0.45,
          "cause": "deep mucosal injury (Crohn) or continuous (UC)"
        }
      ]
    },
    "Irritable Bowel Syndrome": {
      "_review_status": "unreviewed",
      "description": "Functional GI disorder — altered motility + visceral hypersensitivity.",
      "perturbations": [
        {
          "variable": "visceral_nociception",
          "delta": 0.5,
          "cause": "visceral hypersensitivity"
        },
        {
          "variable": "motility",
          "delta": 0.3,
          "cause": "altered (variable) bowel transit"
        }
      ]
    },
    "Hemorrhoids": {
      "_review_status": "unreviewed",
      "description": "Engorged anorectal venous plexus — internal or external.",
      "perturbations": [
        {
          "variable": "mucosal_ulceration",
          "delta": 0.3,
          "cause": "friction during defecation"
        }
      ]
    },
    "Celiac Disease": {
      "_review_status": "unreviewed",
      "description": "Autoimmune reaction to gluten → villous atrophy in small bowel.",
      "perturbations": [
        {
          "variable": "mucosal_inflammation",
          "delta": 0.55,
          "cause": "gliadin-triggered T-cell inflammation"
        },
        {
          "variable": "malabsorption",
          "delta": 0.65,
          "cause": "villous atrophy → reduced absorptive surface"
        }
      ]
    }
  }
}