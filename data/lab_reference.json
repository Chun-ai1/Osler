        "lactic_acidosis",
        "uremia",
        "toxic_ingestion"
      ]
    },
    "glucose": {
      "unit": "mg/dL",
      "normal_low": 70,
      "normal_high": 110,
      "high_means": [
        "diabetes",
        "stress_hyperglycemia",
        "DKA_HHS"
