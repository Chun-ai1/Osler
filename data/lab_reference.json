{
  "_meta": {
    "version": "1.0",
    "description": "LAYER 5: Lab value reference ranges + abnormal interpretation",
    "consumed_by": "PureMechanismDiagnoser + cascade lab markers"
  },
  "labs": {
    "WBC": {
      "unit": "10^9/L",
      "normal_low": 4.0,
      "normal_high": 11.0,
      "high_means": [
        "bacterial_infection",
        "stress_response",
        "leukemia"
      ],
      "low_means": [
        "viral_infection_severe",
        "neutropenia",
        "sepsis_late"
      ]
    },
    "neutrophils_pct": {
      "unit": "%",
      "normal_low": 40,
      "normal_high": 75,
      "high_means": [
        "bacterial_infection",
        "acute_inflammation"
      ],
      "low_means": [
        "viral_infection",
        "neutropenia"
      ]
    },
    "lymphocytes_pct": {
      "unit": "%",
      "normal_low": 20,
      "normal_high": 45,
      "high_means": [
        "viral_infection",
        "lymphocytic_leukemia"
      ],
      "low_means": [
        "acute_bacterial_infection",
        "steroid_use"
      ]
    },
    "bands_pct": {
      "unit": "%",
      "normal_low": 0,
      "normal_high": 3,
      "high_means": [
        "severe_bacterial_infection",
        "left_shift"
      ]
    },
    "Hgb": {
      "unit": "g/dL",
      "normal_low": 12,
      "normal_high": 16,
      "low_means": [
        "anemia",
        "chronic_blood_loss",
        "iron_deficiency"
      ]
    },
    "MCV": {
      "unit": "fL",
      "normal_low": 80,
      "normal_high": 100,
      "low_means": [
        "iron_deficiency_anemia_microcytic"
      ],
      "high_means": [
        "B12_folate_deficiency_macrocytic"
      ]
    },
    "platelets": {
      "unit": "10^9/L",
      "normal_low": 150,
      "normal_high": 450,
      "low_means": [
        "DIC",
        "ITP",
        "TTP",
        "sepsis"
      ],
      "high_means": [
        "reactive_thrombocytosis",
        "MPN"
      ]
    },
    "CRP": {
      "unit": "mg/L",
      "normal_low": 0,
      "normal_high": 10,
