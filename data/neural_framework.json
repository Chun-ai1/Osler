{
  "_metadata": {
    "framework": "neural",
    "schema_version": "2.0",
    "description": "Neural propagation framework. Encodes: (1) referred-pain pathways (15), (2) cranial nerves (12), (3) spinal segments (31), (4) autonomic pathways (sympathetic chain + parasympathetic cranial + sacral), (5) neural propagation rules.",
    "source": "Gray's Anatomy 41e; Adams & Victor; Kandel; Netter Atlas",
    "review_status": "unreviewed"
  },
  "referred_pain_pathways": [
    {"name": "cardiac_to_chest_arm", "visceral_organ": "heart", "trigger_state": "ischemia", "trigger_threshold": 0.5,
     "spinal_segments": ["T1", "T2", "T3", "T4", "T5"],
     "somatic_referral": ["chest wall", "left arm", "jaw"],
     "rationale": "cardiac visceral afferents T1-T5 converge with somatic afferents",
     "review_status": "unreviewed"},
    {"name": "gallbladder_to_shoulder", "visceral_organ": "gallbladder", "trigger_state": "inflammation", "trigger_threshold": 0.5,
     "spinal_segments": ["C3", "C4", "C5"],
     "somatic_referral": ["right shoulder tip"],
     "rationale": "phrenic afferents (C3-C5) — gallbladder irritation",
     "review_status": "unreviewed"},
    {"name": "appendix_to_periumbilical", "visceral_organ": "gi", "trigger_state": "inflammation", "trigger_threshold": 0.4,
     "spinal_segments": ["T10"],
     "somatic_referral": ["periumbilical"],
     "rationale": "midgut afferents enter T10 — early appendicitis",
     "review_status": "unreviewed"},
    {"name": "kidney_to_flank", "visceral_organ": "kidney", "trigger_state": "parenchymal_inflammation", "trigger_threshold": 0.5,
     "spinal_segments": ["T10", "T11", "T12", "L1"],
     "somatic_referral": ["flank", "costovertebral angle"],
     "rationale": "renal capsule afferents T10-L1",
     "review_status": "unreviewed"},
    {"name": "ureter_to_groin", "visceral_organ": "kidney", "trigger_state": "ureteral_distension", "trigger_threshold": 0.5,
     "spinal_segments": ["T11", "T12", "L1", "L2"],
     "somatic_referral": ["flank", "groin", "scrotum_or_labia"],
     "rationale": "ureteral peristalsis vs stone — loin to groin pain",
     "review_status": "unreviewed"},
    {"name": "diaphragm_to_shoulder", "visceral_organ": "diaphragm", "trigger_state": "inflammation", "trigger_threshold": 0.5,
     "spinal_segments": ["C3", "C4", "C5"],
     "somatic_referral": ["shoulder"],
     "rationale": "phrenic afferents → ipsilateral shoulder",
     "review_status": "unreviewed"},
    {"name": "bladder_to_suprapubic", "visceral_organ": "bladder", "trigger_state": "inflammation", "trigger_threshold": 0.5,
     "spinal_segments": ["T11", "T12", "L1", "L2"],
     "somatic_referral": ["suprapubic"],
     "rationale": "bladder afferents T11-L2",
     "review_status": "unreviewed"},
    {"name": "esophageal_to_retrosternal", "visceral_organ": "gi", "trigger_state": "acid_exposure", "trigger_threshold": 0.5,
     "spinal_segments": ["T1", "T2", "T3", "T4", "T5"],
     "somatic_referral": ["retrosternal chest"],
     "rationale": "esophageal afferents share T1-T5 with cardiac — GERD mimics angina",
     "review_status": "unreviewed"},
    {"name": "spleen_to_left_shoulder", "visceral_organ": "spleen", "trigger_state": "inflammation", "trigger_threshold": 0.6,
     "spinal_segments": ["C3", "C4", "C5"],
     "somatic_referral": ["left shoulder"],
     "rationale": "splenic rupture → left hemidiaphragm → phrenic — Kehr sign",
     "review_status": "unreviewed"},
    {"name": "uterus_to_low_back", "visceral_organ": "reproductive", "trigger_state": "contraction", "trigger_threshold": 0.5,
     "spinal_segments": ["T10", "T11", "T12", "L1"],
     "somatic_referral": ["lower back", "suprapubic"],
     "rationale": "uterine afferents T10-L1 — labor pain, dysmenorrhea",
     "review_status": "unreviewed"},
    {"name": "liver_to_right_shoulder", "visceral_organ": "liver", "trigger_state": "hepatocyte_inflammation", "trigger_threshold": 0.6,
     "spinal_segments": ["C3", "C4", "C5"],
     "somatic_referral": ["right shoulder"],
     "rationale": "hepatic capsule stretch → phrenic afferents",
     "review_status": "unreviewed"},
    {"name": "pancreas_to_back", "visceral_organ": "pancreas", "trigger_state": "exocrine_inflammation", "trigger_threshold": 0.5,
     "spinal_segments": ["T6", "T7", "T8", "T9", "T10"],
     "somatic_referral": ["epigastric", "mid-back"],
     "rationale": "retroperitoneal pancreas → splanchnic afferents",
     "review_status": "unreviewed"},
    {"name": "ovary_to_groin", "visceral_organ": "reproductive", "trigger_state": "ovarian_torsion", "trigger_threshold": 0.5,
     "spinal_segments": ["T10", "T11"],
     "somatic_referral": ["lower abdomen", "groin"],
     "rationale": "ovary embryologically T10 origin",
     "review_status": "unreviewed"},
    {"name": "testis_to_loin", "visceral_organ": "reproductive", "trigger_state": "inflammation", "trigger_threshold": 0.5,
     "spinal_segments": ["T10"],
     "somatic_referral": ["loin", "periumbilical"],
     "rationale": "testicular afferents follow embryonic origin",
     "review_status": "unreviewed"},
    {"name": "stomach_to_epigastrium", "visceral_organ": "gi", "trigger_state": "mucosal_inflammation", "trigger_threshold": 0.5,
     "spinal_segments": ["T6", "T7", "T8", "T9"],
     "somatic_referral": ["epigastric"],
     "rationale": "gastric foregut afferents T6-T9",
     "review_status": "unreviewed"}
  ],
  "cranial_nerves": {
    "CN1_olfactory": {"modality": "special_sensory", "function": "olfaction", "atlas_organ": "brain",
      "lesion_symptom": "anosmia", "common_causes": ["head trauma", "viral infection", "tumor"]},
    "CN2_optic": {"modality": "special_sensory", "function": "vision", "atlas_organ": "retina",
      "lesion_symptom": "visual loss / field defect", "common_causes": ["optic neuritis", "ischemic ON", "compression"]},
    "CN3_oculomotor": {"modality": "motor", "function": "eye movement + lid + pupil constriction", "atlas_organ": "midbrain",
      "lesion_symptom": "ptosis + down-and-out + mydriasis", "common_causes": ["PCom aneurysm", "diabetes", "herniation"]},
    "CN4_trochlear": {"modality": "motor", "function": "superior oblique", "atlas_organ": "midbrain",
      "lesion_symptom": "vertical diplopia on downgaze", "common_causes": ["trauma", "congenital"]},
    "CN5_trigeminal": {"modality": "mixed_sensory_motor", "function": "face sensation + mastication", "atlas_organ": "trigeminal_nerve",
      "lesion_symptom": "facial numbness or trigeminal neuralgia", "common_causes": ["vascular compression", "MS", "acoustic neuroma"]},
    "CN6_abducens": {"modality": "motor", "function": "lateral rectus", "atlas_organ": "pons",
      "lesion_symptom": "horizontal diplopia on lateral gaze", "common_causes": ["raised ICP", "ischemia", "trauma"]},
    "CN7_facial": {"modality": "mixed", "function": "facial motor + taste + lacrimation", "atlas_organ": "facial_nerve",
      "lesion_symptom": "facial droop (LMN includes forehead)", "common_causes": ["Bell's palsy", "stroke (UMN)", "tumor"]},
    "CN8_vestibulocochlear": {"modality": "special_sensory", "function": "hearing + balance", "atlas_organ": "middle_ear",
      "lesion_symptom": "hearing loss + vertigo + tinnitus", "common_causes": ["acoustic neuroma", "Meniere's", "vestibular neuritis"]},
    "CN9_glossopharyngeal": {"modality": "mixed", "function": "post tongue taste + gag afferent + parotid", "atlas_organ": "medulla",
      "lesion_symptom": "loss of gag reflex (afferent)", "common_causes": ["skull base tumor", "lateral medullary stroke"]},
    "CN10_vagus": {"modality": "mixed", "function": "palate + pharynx + parasympathetic to viscera", "atlas_organ": "medulla",
      "lesion_symptom": "hoarseness + dysphagia + uvula deviation", "common_causes": ["lung/thyroid tumor", "stroke", "aneurysm"]},
    "CN11_accessory": {"modality": "motor", "function": "SCM + trapezius", "atlas_organ": "medulla",
      "lesion_symptom": "shoulder droop + weak head turn", "common_causes": ["surgical injury", "trauma"]},
    "CN12_hypoglossal": {"modality": "motor", "function": "tongue motor", "atlas_organ": "medulla",
      "lesion_symptom": "tongue deviates toward lesion", "common_causes": ["medial medullary stroke", "tumor", "ALS"]}
  },
