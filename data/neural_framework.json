  "autonomic_pathways": {
    "sympathetic_chain": {
      "preganglionic_origin": "T1-L2 intermediolateral cell column",
      "ganglia": ["superior cervical", "middle cervical", "stellate (cervicothoracic)",
                  "thoracic chain T1-T12", "lumbar chain L1-L2",
                  "celiac (T5-T9 splanchnics)", "superior mesenteric (T10-T11)", "inferior mesenteric (T12-L2)"],
      "key_innervations": {
        "head": "superior cervical → pupil dilation, lid, salivary, sweat",
        "heart": "T1-T4 → rate↑, contractility↑",
        "lung": "T1-T4 → bronchodilation",
        "abdominal_viscera": "T5-L2 via splanchnics → celiac/SMA/IMA plexuses",
        "skin": "T1-L2 → vasoconstriction, sweat, piloerection"
      },
      "review_status": "unreviewed"
    },
    "parasympathetic_cranial": {
      "outflow": "CN3, CN7, CN9, CN10",
      "key_innervations": {
        "CN3 (Edinger-Westphal)": "pupil constriction, accommodation",
        "CN7 (superior salivatory)": "lacrimation, salivation (submandibular)",
        "CN9 (inferior salivatory)": "parotid",
        "CN10 (vagus)": "heart rate↓, lung bronchoconstriction, GI motility↑, foregut to mid-transverse colon"
      },
      "review_status": "unreviewed"
    },
    "parasympathetic_sacral": {
      "outflow": "S2-S4 pelvic splanchnic",
      "key_innervations": {
        "hindgut": "distal transverse colon → rectum motility↑",
        "bladder": "detrusor contraction",
        "reproductive": "erection, clitoral engorgement"
      },
      "review_status": "unreviewed"
    }
  },
  "neural_propagation_rules": [
    {"name": "intracranial_pressure_to_brainstem",
     "trigger": {"organ": "brain", "state": "intracranial_pressure", "op": ">", "threshold": 0.7},
     "effect":  {"organ": "brain", "state": "brainstem_compression", "delta": 0.5},
     "via": "neural",
     "rationale": "elevated ICP → herniation → brainstem compression",
     "review_status": "unreviewed"},
    {"name": "sympathetic_overdrive_to_heart",
     "trigger": {"organ": "brain", "state": "sympathetic_outflow", "op": ">", "threshold": 0.7},
     "effect":  {"organ": "heart", "state": "electrical_instability", "delta": 0.3},
     "via": "neural",
     "rationale": "catecholamine surge → arrhythmia (SAH cardiomyopathy)",
     "review_status": "unreviewed"},
    {"name": "vagal_tone_to_gi",
     "trigger": {"organ": "brain", "state": "vagal_drive", "op": ">", "threshold": 0.6},
     "effect":  {"organ": "gi", "state": "motility", "delta": 0.3},
     "via": "neural",
     "rationale": "parasympathetic outflow → GI motility ↑",
     "review_status": "unreviewed"},
    {"name": "pain_to_sympathetic_surge",
     "trigger": {"organ": "muscle", "state": "inflammation", "op": ">", "threshold": 0.6},
     "effect":  {"organ": "heart", "state": "sympathetic_drive", "delta": 0.2},
     "via": "neural",
     "rationale": "severe pain → reflex sympathetic activation",
     "review_status": "unreviewed"}
  ]
}